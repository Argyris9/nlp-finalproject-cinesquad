# Copy this file to .env and fill in your own key -- .env is gitignored,
# never commit real API keys.

# Optional. If set, backend/services/generator_service.py uses Gemini
# (free tier) for chat generation instead of the local flan-t5-base model.
# Get a free key at https://aistudio.google.com/apikey
GEMINI_API_KEY=

# Optional, defaults to gemini-2.5-flash if not set. (gemini-2.0-flash had
# 0 free-tier quota when tested -- gemini-2.5-flash and gemini-flash-latest
# both work on the free tier.)
GEMINI_MODEL=gemini-2.5-flash
