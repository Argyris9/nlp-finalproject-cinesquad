# Copy this file to .env.production and fill in your deployed backend's
# URL before running `npm run build` for a production/Cloudflare deploy.
# Vite bakes this in at build time -- it has no effect at runtime, so it
# must be set before you build, not after.
#
# Local dev doesn't need this file at all; it defaults to
# http://127.0.0.1:8000.
# Cloud Run prints this URL after `gcloud run deploy` completes.
VITE_API_BASE_URL=https://your-service-name-xxxxxxxxxx.a.run.app
